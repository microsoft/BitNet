[Unit]
Description=BitNet inference service (llama-cli)
After=network.target

[Service]
Type=simple
WorkingDirectory=/workspaces/BitNet
ExecStart=/usr/bin/env bash /workspaces/BitNet/scripts/run_bitnet.sh /workspaces/BitNet/models/BitNet-b1.58-2B-4T/ggml-model-i2_s.gguf "You are a helpful assistant." 4 256
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
